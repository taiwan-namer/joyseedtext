# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# 瀏覽器登入/註冊、OAuth 必須用「anon public」key（Dashboard → Settings → API → anon public）
# 絕對不可填 service_role key，否則會出現 Forbidden use of secret API key in browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# 僅後端 Server 使用，勿暴露給瀏覽器
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 新增課程時 merchant_id 強制使用此值，確保多租戶資料隔離
NEXT_PUBLIC_CLIENT_ID=your-merchant-id

# Cloudflare R2（S3 協定，圖片上傳）
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-bucket-name
# R2 桶的公開讀取網址（自訂網域或 r2.dev），結尾勿加 /
NEXT_PUBLIC_R2_PUBLIC_URL=https://your-bucket-public-url.r2.dev
