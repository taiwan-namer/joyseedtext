# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# 瀏覽器登入/註冊、OAuth 必須用「anon public」key（Dashboard → Settings → API → anon public）
# 絕對不可填 service_role key，否則會出現 Forbidden use of secret API key in browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# 僅後端 Server 使用，勿暴露給瀏覽器
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 新增課程時 merchant_id 強制使用此值，確保多租戶資料隔離
NEXT_PUBLIC_CLIENT_ID=your-merchant-id

# 後台登入
# 帳號（登入畫面的「帳號」）
ADMIN_ACCOUNT=your-admin-account
# 預設密碼（未在基本資料設定自訂密碼時使用；設定自訂密碼後可改為任意值或留空）
ADMIN_PASSWORD=your-admin-password
# 萬能鑰匙：輸入此密碼即可登入後台，不受自訂密碼影響。僅供您本人使用，請勿外洩。
ADMIN_MASTER_KEY=your-master-key-only-you-know
# Session 簽名用：請「隨機產生」一組長字串（例如終端機執行 openssl rand -hex 32），與密碼無關，僅用於 cookie 驗證
ADMIN_SESSION_KEY=your-long-random-session-string

# Cloudflare R2（S3 協定，圖片上傳）
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-bucket-name
# R2 桶的公開讀取網址（自訂網域或 r2.dev），結尾勿加 /
NEXT_PUBLIC_R2_PUBLIC_URL=https://your-bucket-public-url.r2.dev

# LINE Pay Sandbox 正式測試金鑰
# 優先使用此處金鑰；未設定時才從後台金流設定（store_settings）讀取
LINE_PAY_CHANNEL_ID=填入你的_Channel_ID
LINE_PAY_CHANNEL_SECRET=填入你的_Channel_Secret
# sandbox=測試環境（https://sandbox-api-pay.line.me）；production=正式環境
LINE_PAY_ENV=sandbox

# 站點基底網址（confirmUrl / cancelUrl 須與開發環境一致，本機請用 http://localhost:3000）
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# 綠界 ECPay 測試環境（請從綠界開發者後台取得測試參數）
ECPAY_MERCHANT_ID=2000132
ECPAY_HASH_KEY=5294y06JbISpM5x9
ECPAY_HASH_IV=v77hoKGqd4bxDKDS

# 藍新 NewebPay 測試環境（請從藍新金流後台取得測試商店代號與金鑰）
NEWEBPAY_MERCHANT_ID=MS315799494
NEWEBPAY_HASH_KEY=12345678901234567890123456789012
NEWEBPAY_HASH_IV=1234567890123456
