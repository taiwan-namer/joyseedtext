# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# 瀏覽器登入/註冊、OAuth 必須用「anon public」key（Dashboard → Settings → API → anon public）
# 絕對不可填 service_role key，否則會出現 Forbidden use of secret API key in browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# 僅後端 Server 使用，勿暴露給瀏覽器
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 分站 SEO：總站 Canonical / metadataBase（完整網址，結尾可加 /）。未設則預設 https://www.joyseedisland.com.tw
NEXT_PUBLIC_CANONICAL_ORIGIN=https://www.joyseedisland.com.tw/
# 選填：舊變數名，僅在未設 NEXT_PUBLIC_CANONICAL_ORIGIN 時生效
# MAIN_SITE_CANONICAL_ORIGIN=

# 新增課程時 merchant_id 強制使用此值，確保多租戶資料隔離。
# 總站後台 build：請與 DB 內總站課程的 merchant_id 一致，「自動產列表配對碼／一鍵綁老師課」UI 才會出現。
NEXT_PUBLIC_CLIENT_ID=your-merchant-id

# 選填：設為 true 時，後台新增/編輯課程顯示總站進階欄位（網址代稱手動、分站自訂分類、所屬商家、代銷配對、總站列表對應、庫存綁定）。
# 未設或 false＝分站精簡表單（merchant_id 固定為本站的 NEXT_PUBLIC_CLIENT_ID；代稱僅由標題自動產生）。
NEXT_PUBLIC_HQ_COURSE_ADMIN_UI=

# 選填：後台「訂單管理／匯出／待付款」一併顯示其他商家的訂單（同一 Supabase、下單站 CLIENT_ID 與後台不同時使用）。
# 逗號或換行分隔，勿加空白以外的多餘字元。例：joyseed-hq,teacher-store-a
BOOKINGS_ADMIN_VISIBLE_MERCHANT_IDS=

# 選填：後台訂單／匯出／待付款**僅**顯示「開課商家」= 此值的訂單（對應 DB bookings.class_creator_merchant_id，即該堂課 classes.merchant_id）。
# 若設定此變數，會優先於 BOOKINGS_ADMIN_VISIBLE_MERCHANT_IDS，避免撈到整個 MODEL 底下所有 merchant 的訂單。需先在 Supabase 套用 migration 新增欄位並回填。
BOOKINGS_ORDER_ADMIN_CLASS_CREATOR_MERCHANT_ID=

# 選填：分站後台／會員／儀表板「顯示金額」時，從 order_amount 扣除名稱含以下子字串的加購（對應 classes.addon_prices + addon_indices）。例：總站專屬「安心包」不計入分站營收顯示。逗號分隔，未設定則不扣除。
BOOKINGS_BRANCH_EXCLUDE_ADDON_NAMES_FROM_AMOUNT=

# 後台登入
# 帳號（登入畫面的「帳號」）
ADMIN_ACCOUNT=your-admin-account
# 預設密碼（未在基本資料設定自訂密碼時使用；設定自訂密碼後可改為任意值或留空）
ADMIN_PASSWORD=your-admin-password
# 萬能鑰匙：輸入此密碼即可登入後台，不受自訂密碼影響。僅供您本人使用，請勿外洩。
ADMIN_MASTER_KEY=your-master-key-only-you-know
# Session 簽名用：請「隨機產生」一組長字串（例如終端機執行 openssl rand -hex 32），與密碼無關，僅用於 cookie 驗證
ADMIN_SESSION_KEY=your-long-random-session-string

# Cloudflare R2（S3 協定，圖片上傳）
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-bucket-name
# R2 桶的公開讀取網址（自訂網域或 r2.dev），結尾勿加 /
NEXT_PUBLIC_R2_PUBLIC_URL=https://your-bucket-public-url.r2.dev

# 綠界 ECPay（測試環境請用官方「測試介接資訊」：MerchantID=2000132, HashKey=ejCk326UnaZWKisg, HashIV=q9jcZX8Ib9LM8wYk）
ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=
# 正式環境請設 ECPAY_ENV=production
# 綠界回傳／callback 統一使用此網址，避免 preview 網域混入。可與 NEXT_PUBLIC_BASE_URL 擇一或並存（例：https://model-5lqo.vercel.app）
APP_URL=

# 綠界電子發票（B2CInvoice/Issue，發票金鑰與金流「完全獨立」，請至綠界電子發票後台取得專用測試／正式金鑰）
# 僅供後端使用，請勿在前端程式中引用或透過瀏覽器曝光
ECPAY_INVOICE_MERCHANT_ID=
ECPAY_INVOICE_HASH_KEY=
ECPAY_INVOICE_HASH_IV=

# 藍新 NewebPay（單一來源：lib/newebpay/config.ts）
# 測試環境：actionUrl=ccore.newebpay.com/MPG/mpg_gateway，必須使用「藍新測試後台」開立商店後取得的測試商店代號、HashKey、HashIV
# 正式環境：設 NEWEBPAY_ENV=production，並使用正式商店代號與金鑰。測試商店代號在正式站會回傳 MPG03007 查無此商店代號
NEWEBPAY_MERCHANT_ID=
NEWEBPAY_HASH_KEY=
NEWEBPAY_HASH_IV=
DEEPSEEK_API_KEY=

# 選填：與總站伺服器 ADMIN_SESSION_KEY 相同，供後端呼叫總站「分站供應商註冊連結 mint」（Authorization: Bearer）。勿與本分站 ADMIN_SESSION_KEY 混用。綁定／審核狀態改由 Supabase 表讀取，不需此 key。
HQ_ADMIN_SESSION_KEY=
# 選填：設為 1 時略過商品管理／新增課程的供應商綁定閘道（僅本機除錯）
DISABLE_VENDOR_GATE_ADD_COURSE=